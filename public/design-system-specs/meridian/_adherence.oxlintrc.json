{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/bio/**",
              "components/charts/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/health/**",
              "components/navigation/**",
              "ui_kits/app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Metropolis))/i]",
        "message": "Font not provided by the design system. Available: Metropolis."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActivityRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|channel|duration|label|start|end|meta|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ActivityRow> doesn't accept that prop. Declared props: icon, channel, duration, label, start, end, meta, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActivityRow'] > JSXAttribute[name.name='icon'] > Literal[value!=/^(?:moon|activity|heart|run)$/]",
        "message": "<ActivityRow> icon must be one of 'moon' | 'activity' | 'heart' | 'run'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActivityRow'] > JSXAttribute[name.name='channel'] > Literal[value!=/^(?:sleep|strain|recovery|stress)$/]",
        "message": "<ActivityRow> channel must be one of 'sleep' | 'strain' | 'recovery' | 'stress'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|tone|ring|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, tone, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|warm|violet|slate)$/]",
        "message": "<Avatar> tone must be one of 'brand' | 'warm' | 'violet' | 'slate'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|size|dot|icon|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, size, dot, icon, style."
