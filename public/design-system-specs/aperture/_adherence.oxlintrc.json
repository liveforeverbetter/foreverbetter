{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/data/**",
              "components/feedback/**",
              "components/inputs/**",
              "components/layout/**",
              "ui_kits/aperture-app/**",
              "ui_kits/aperture-dashboard/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fustat|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Fustat, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActivityRingSpec'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|color|track|key|ref|className|style|children)$/]",
        "message": "<ActivityRingSpec> doesn't accept that prop. Declared props: value, max, color, track."
      },
      {
        "selector": "JSXOpeningElement[name.name='AreaChart'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|color|fillOpacity|height|min|max|targetBand|xLabels|yTicks|smooth|key|ref|className|style|children)$/]",
        "message": "<AreaChart> doesn't accept that prop. Declared props: data, color, fillOpacity, height, min, max, targetBand, xLabels, yTicks, smooth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|fullWidth|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, fullWidth, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|brand|secondary|soft|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'brand' | 'secondary' | 'soft' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|radius|padding|glow|interactive|gradient|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: tone, radius, padding, glow, interactive, gradient, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:md|lg|xl)$/]",
        "message": "<Card> radius must be one of 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|label|active|disabled|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size, label, active, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|soft|solid|outline)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'soft' | 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|hint|error|wrapStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, icon, hint, error, wrapStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='InsightBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|body|icon|tone|gradient|glow|dots|activeDot|action|key|ref|className|style|children)$/]",
        "message": "<InsightBanner> doesn't accept that prop. Declared props: eyebrow, title, body, icon, tone, gradient, glow, dots, activeDot, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|iconTone|title|subtitle|value|valueUnit|trailing|chevron|divider|onClick|key|ref|className|style|children)$/]",
        "message": "<ListItem> doesn't accept that prop. Declared props: icon, iconTone, title, subtitle, value, valueUnit, trailing, chevron, divider, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|status|statusTone|icon|iconTone|hint|onClick|key|ref|className|style|children)$/]",
        "message": "<MetricTile> doesn't accept that prop. Declared props: label, value, unit, status, statusTone, icon, iconTone, hint, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricTile'] > JSXAttribute[name.name='statusTone'] > Literal[value!=/^(?:excellent|good|fair|attention)$/]",
        "message": "<MetricTile> statusTone must be one of 'excellent' | 'good' | 'fair' | 'attention'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|children|actions|onClose|sheet|width|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: title, subtitle, children, actions, onClose, sheet, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|size|thickness|color|track|rounded|children|key|ref|className|style|children)$/]",
        "message": "<ProgressRing> doesn't accept that prop. Declared props: value, max, size, thickness, color, track, rounded, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='RangeGauge'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|band|leftLabel|rightLabel|status|statusTone|height|key|ref|className|style|children)$/]",
        "message": "<RangeGauge> doesn't accept that prop. Declared props: value, band, leftLabel, rightLabel, status, statusTone, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='RangeGauge'] > JSXAttribute[name.name='statusTone'] > Literal[value!=/^(?:excellent|good|fair|attention)$/]",
        "message": "<RangeGauge> statusTone must be one of 'excellent' | 'good' | 'fair' | 'attention'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|max|band|tone|delta|unit|description|footer|radius|key|ref|className|style|children)$/]",
        "message": "<ScoreCard> doesn't accept that prop. Declared props: score, max, band, tone, delta, unit, description, footer, radius."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:excellent|good|fair|attention)$/]",
        "message": "<ScoreCard> tone must be one of 'excellent' | 'good' | 'fair' | 'attention'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreCard'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:lg|xl|2xl)$/]",
        "message": "<ScoreCard> radius must be one of 'lg' | 'xl' | '2xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: id, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='SidebarItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|badge|section|key|ref|className|style|children)$/]",
        "message": "<SidebarItem> doesn't accept that prop. Declared props: id, label, icon, badge, section."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|size|icon|children|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: tone, variant, size, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:excellent|good|fair|attention|success|warning|danger|info)$/]",
        "message": "<StatusPill> tone must be one of 'excellent' | 'good' | 'fair' | 'attention' | 'success' | 'warning' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid|outline)$/]",
        "message": "<StatusPill> variant must be one of 'soft' | 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<StatusPill> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|size|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Switch> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabBarItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|key|ref|className|style|children)$/]",
        "message": "<TabBarItem> doesn't accept that prop. Declared props: id, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|message|icon|action|onDismiss|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: tone, title, message, icon, action, onDismiss."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:good|fair|attention|excellent|success|warning|danger|info)$/]",
        "message": "<Toast> tone must be one of 'good' | 'fair' | 'attention' | 'excellent' | 'success' | 'warning' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|onBack|leading|actions|large|key|ref|className|style|children)$/]",
        "message": "<TopBar> doesn't accept that prop. Declared props: title, onBack, leading, actions, large."
      }
    ]
  },
