{
  "name": "analyze-longevity",
  "version": "1.0.0",
  "description": "Local-first wellness and health-agent pipeline for genomics, biomarkers, and wearable data, with optional cloud mode",
  "type": "module",
  "scripts": {
    "cloud": "npx tsx scripts/pipeline/cloud.ts",
    "design:list": "npx tsx -e \"import('./shared/design/theme.js').then(m=>console.log(m.listBundledSystems()))\"",
    "design:vet": "npx tsx scripts/pipeline/vet-designs.ts",
    "design:preview": "npx tsx scripts/pipeline/preview-designs.ts",
    "pipeline": "npx tsx scripts/pipeline/index.ts",
    "render": "npx tsx scripts/pipeline/render-dashboard.ts",
    "sample:report": "npx tsx scripts/pipeline/render-sample-report.ts",
    "smoke:wgs": "npx tsx scripts/pipeline/index.ts examples/sample-rsid-wgs.vcf sample_wgs_smoke ./output --biomarkers=examples/sample-biomarkers.csv --biomarkers-previous=examples/sample-biomarkers-previous.csv --wearables=examples/sample-whoop-api.json",
    "doctor": "npx tsx scripts/pipeline/distribution_doctor.ts",
    "evaluate": "npx tsx scripts/pipeline/evaluate-report.ts",
    "audit:pipeline": "npx tsx scripts/pipeline/audit-pipeline.ts",
    "whoop:sync": "npx tsx scripts/pipeline/whoop_api_client.ts",
    "catalog:build": "npx tsx scripts/pipeline/compact_interpretation_catalog.ts",
    "genetics:catalog": "npx tsx scripts/pipeline/genetics_report_catalog.ts",
    "genetics:benchmark": "npx tsx scripts/pipeline/genetics_benchmark.ts",
    "vcf:coverage": "npx tsx scripts/pipeline/local_vcf_coverage.ts",
    "biomarkers:validate": "npx tsx scripts/pipeline/biomarker_validation.ts",
    "biomarkers:benchmark": "npx tsx scripts/pipeline/biomarker_benchmark.ts",
    "wgs:variant-classes": "npx tsx scripts/pipeline/wgs_variant_class_engine.ts",
    "wgs:caller-manifest": "npx tsx scripts/pipeline/wgs_caller_pipeline.ts",
    "wgs:query-readiness": "npx tsx scripts/pipeline/wgs_query_readiness.ts",
    "wgs:validate": "npx tsx scripts/pipeline/wgs_validation.ts",
    "wgs:external-validation": "npx tsx scripts/pipeline/wgs_external_validation.ts",
    "wgs:truthsets": "npx tsx scripts/pipeline/wgs_external_truthset_setup.ts",
    "reference:doctor": "npx tsx scripts/pipeline/reference_doctor.ts",
    "reference:setup": "npx tsx scripts/reference-setup/setup-references.ts && npm run gwas:build",
    "reference:wellness": "npx tsx scripts/reference-setup/setup-wellness-references.ts",
    "setup:rsids": "npx tsx scripts/reference-setup/setup-clinvar-rsids.ts",
    "doctor:vcf": "npx tsx scripts/pipeline/vcf_doctor.ts",
    "annotate:vcf": "npx tsx scripts/ingestion/annotate-vcf.ts",
    "reference:fixtures": "npx tsx --test scripts/pipeline/wgs_reference_validation.test.ts",
    "cnv:validate": "npx tsx scripts/pipeline/cnv_sv_repeat_evidence_validation.ts",
    "interpretation:depth": "npx tsx scripts/pipeline/interpretation_depth_metrics.ts",
    "test": "npm run test:all",
    "test:all": "npx tsx --test scripts/pipeline/*.test.ts shared/*.test.ts",
    "test:renderer": "npx tsx src/renderer/smoke-test.ts",
    "typecheck": "tsc --noEmit",
    "analyze": "npx tsx scripts/ingestion/parse-vcf.ts",
    "sync": "npx tsx scripts/sync/wearable-sync.ts --sync",
    "connect": "npx tsx scripts/sync/wearable-sync.ts --connect",
    "sync:status": "npx tsx scripts/sync/wearable-sync.ts --status",
    "import:google": "npx tsx scripts/sync/wearable-sync.ts --import-google",
    "gwas:build": "npx tsx scripts/reference-build/build-gwas-reference.ts"
  },
  "keywords": [
    "analyze-longevity",
    "health-agent",
    "wellness",
    "biomarkers",
    "wearables",
    "genomics",
    "bioinformatics",
    "WGS",
    "VCF",
    "healthspan",
    "longevity"
  ],
  "author": "foreverbetter",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
