        "curl -L -o reference/dbsnp/GCF_000001405.40.gz.tbi https://ftp.ncbi.nlm.nih.gov/snp/latest_release/VCF/GCF_000001405.40.gz.tbi",
        "curl -L -o reference/dbsnp/GCF_000001405.40.gz.md5 https://ftp.ncbi.nlm.nih.gov/snp/latest_release/VCF/GCF_000001405.40.gz.md5"
