{
  "version": "2026-06-09",
  "purpose": "Optional heavyweight reference assets for full WGS annotation and external validation. These assets are intentionally not bundled with the repo; the doctor checks local presence and prints setup guidance.",
  "bloat_policy": {
    "bundle_in_repo": false,
    "local_cache_roots": [
      "../../reference/dbsnp",
      "../../reference/clinvar",
      "../../reference/wellness/raw",
      "../../reference/vep",
      "../../external-truthsets",
      "../../caller-output"
    ],
    "notes": [
      "Keep full dbSNP, raw GWAS/PGS source downloads, VEP caches, GIAB truthsets, BAM/CRAM/FASTQ caller outputs, and generated query VCFs out of git.",
      "Commit compact derived references only when they stay below GitHub file-size limits and provide meaningful default runtime behavior."
    ]
  },
  "assets": [
    {
      "id": "wellness_gwas_pgs_raw_cache",
      "group": "wellness",
      "label": "Raw GWAS Catalog and PGS Catalog cache for rebuilding compact wellness references",
      "version": "latest",
      "genome_build": "mixed; PGS scoring files harmonized to GRCh37 where available",
      "source": "NHGRI-EBI GWAS Catalog and PGS Catalog",
      "source_page": "https://www.ebi.ac.uk/gwas/docs/file-downloads",
      "required_for": [
        "Rebuilding reference/wellness compact GWAS/PGS association files"
      ],
      "expected_files": [
        {
          "path": "reference/wellness/raw/gwas-catalog-associations_ontology-annotated-full.zip",
          "filename": "gwas-catalog-associations_ontology-annotated-full.zip",
          "url": "https://ftp.ebi.ac.uk/pub/databases/gwas/releases/latest/gwas-catalog-associations_ontology-annotated-full.zip",
          "expected_size": "65M",
          "required": false
        },
        {
          "path": "reference/wellness/raw/pgs_all_metadata.tar.gz",
          "filename": "pgs_all_metadata.tar.gz",
          "url": "https://ftp.ebi.ac.uk/pub/databases/spot/pgs/metadata/pgs_all_metadata.tar.gz",
          "expected_size": "4M",
          "required": false
        }
      ],
      "setup_commands": [
        "npm run reference:wellness"
      ]
    },
    {
      "id": "dbsnp_grch37_latest_vcf",
      "group": "dbsnp",
      "label": "NCBI dbSNP latest human GRCh37 VCF",
      "version": "latest_release 2025-01-15 listing",
      "genome_build": "GRCh37 / GCF_000001405.25",
      "source": "NCBI dbSNP FTP",
      "source_page": "https://ftp.ncbi.nlm.nih.gov/snp/latest_release/VCF/",
      "required_for": [
        "rsID annotation for WGS VCFs aligned to GRCh37/hg19"
      ],
      "expected_files": [
        {
          "path": "../../reference/dbsnp/GCF_000001405.25.gz",
          "filename": "GCF_000001405.25.gz",
          "url": "https://ftp.ncbi.nlm.nih.gov/snp/latest_release/VCF/GCF_000001405.25.gz",
          "checksum_url": "https://ftp.ncbi.nlm.nih.gov/snp/latest_release/VCF/GCF_000001405.25.gz.md5",
          "expected_size": "26G",
          "required": true
        },
        {
          "path": "../../reference/dbsnp/GCF_000001405.25.gz.tbi",
          "filename": "GCF_000001405.25.gz.tbi",
          "url": "https://ftp.ncbi.nlm.nih.gov/snp/latest_release/VCF/GCF_000001405.25.gz.tbi",
          "checksum_url": "https://ftp.ncbi.nlm.nih.gov/snp/latest_release/VCF/GCF_000001405.25.gz.tbi.md5",
          "expected_size": "2.9M",
          "required": true
        }
      ],
      "setup_commands": [
        "mkdir -p reference/dbsnp",
        "curl -L -o reference/dbsnp/GCF_000001405.25.gz https://ftp.ncbi.nlm.nih.gov/snp/latest_release/VCF/GCF_000001405.25.gz",
        "curl -L -o reference/dbsnp/GCF_000001405.25.gz.tbi https://ftp.ncbi.nlm.nih.gov/snp/latest_release/VCF/GCF_000001405.25.gz.tbi",
        "curl -L -o reference/dbsnp/GCF_000001405.25.gz.md5 https://ftp.ncbi.nlm.nih.gov/snp/latest_release/VCF/GCF_000001405.25.gz.md5"
      ]
    },
    {
      "id": "dbsnp_grch38_latest_vcf",
      "group": "dbsnp",
      "label": "NCBI dbSNP latest human GRCh38 VCF",
      "version": "latest_release 2025-01-15 listing",
