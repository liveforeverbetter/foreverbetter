  ],
  "tools": [
    {
      "id": "bcftools",
      "command": "bcftools",
      "version_command": "bcftools --version",
      "required_for": [
        "VCF normalization, annotation, indexing, and subsetting"
      ],
      "install_hint": "Install bcftools with conda/bioconda, Homebrew, or the local bioinformatics environment."
    },
    {
      "id": "tabix",
      "command": "tabix",
      "version_command": "tabix --version",
      "required_for": [
        "VCF/tabix index validation"
      ],
      "install_hint": "Install htslib/tabix with conda/bioconda, Homebrew, or the local bioinformatics environment."
    },
    {
      "id": "bgzip",
      "command": "bgzip",
      "version_command": "bgzip --version",
      "required_for": [
        "Blocked gzip compression for VCFs"
      ],
      "install_hint": "Install htslib/bgzip with conda/bioconda, Homebrew, or the local bioinformatics environment."
    },
    {
      "id": "vep",
      "command": "vep",
      "version_command": "vep --help",
      "required_for": [
        "offline VEP annotation"
      ],
      "install_hint": "Install Ensembl VEP and point it at the local reference/vep cache."
    },
    {
      "id": "truvari",
      "command": "truvari",
      "version_command": "truvari version",
      "required_for": [
        "GIAB structural-variant benchmarking"
      ],
      "install_hint": "Install Truvari in the local benchmark environment."
    },
    {
      "id": "hap.py",
      "command": "hap.py",
      "version_command": "hap.py --version",
      "required_for": [
        "GIAB small-variant benchmarking"
      ],
      "install_hint": "Install hap.py through a GIAB/RTG/hap.py container or conda environment."
    }
  ]
}
