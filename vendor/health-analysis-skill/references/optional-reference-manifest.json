    {
      "id": "vep_homo_sapiens_grch37_cache",
      "group": "vep",
      "label": "Ensembl VEP indexed homo_sapiens GRCh37 cache",
      "version": "Ensembl release 115",
      "genome_build": "GRCh37",
      "source": "Ensembl FTP",
      "source_page": "https://ftp.ensembl.org/pub/current_variation/indexed_vep_cache/",
