{
  "version": "2026-06-01",
  "purpose": "Internal Superpower-style biomarker coverage benchmark. This is not rendered to users; it exists so the skill pipeline can score whether biomarker coverage is broad, balanced, quantitative, and trend-ready.",
  "source_notes": [
    "Superpower public baseline describes annual full-body testing across 100+ biomarkers, a dashboard, personalized action plan, wearable/past-lab uploads, 17 health scores, and biological age.",
    "This local benchmark converts that public product shape into deterministic internal checks against the biomarker engine, sample fixtures, and validation reports."
  ],
  "target_supported_markers": 100,
  "target_domains": 7,
  "target_min_domain_depth": 10,
  "target_priority_marker_recall": 0.95,
  "target_derived_metrics": 6,
  "target_truthsets": 3,
  "target_status_recall": 1,
  "target_derived_recall": 1,
  "target_action_completeness": 1,
  "target_trend_overlap": 40,
  "target_system_scores": 17,
  "requires_biological_age_model": true,
  "priority_markers": [
    "apob",
    "ldl_c",
    "hdl_c",
    "triglycerides",
    "total_cholesterol",
    "non_hdl_c",
    "lp_a",
    "fasting_glucose",
    "fasting_insulin",
    "hba1c",
    "homa_ir",
    "hs_crp",
    "ferritin",
    "homocysteine",
    "wbc",
    "neutrophils",
    "lymphocytes",
    "vitamin_d",
    "b12",
    "folate",
    "magnesium",
    "omega3_index",
    "iron",
    "tibc",
    "transferrin_saturation",
    "tsh",
    "free_t4",
    "free_t3",
    "testosterone_total",
    "testosterone_free",
    "estradiol",
    "shbg",
    "dhea_s",
    "cortisol_am",
    "alt",
    "ast",
    "ggt",
    "alp",
    "bilirubin",
    "creatinine",
    "egfr",
    "bun",
    "albumin",
    "hemoglobin",
    "hematocrit",
    "platelets",
    "rdw",
    "mcv",
    "rbc"
  ],
  "derived_metrics": [
    "homa_ir",
    "non_hdl_c",
    "remnant_cholesterol",
    "apob_apoa1_ratio",
    "transferrin_saturation",
    "vldl_c"
  ],
  "expected_system_scores": [
    "cardiovascular_risk",
    "lipid_transport",
    "glucose_control",
    "insulin_resistance",
    "inflammation",
    "immune_balance",
    "iron_status",
